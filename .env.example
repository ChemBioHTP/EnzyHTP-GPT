# 镜像与端口
FLASK_IMAGE_TAG=2025.08.v01
FLASK_HOST_PORT=12306
MONGO_PORT=27017

# 数据与证书路径（替换为你的真实路径）
MONGO_DATA_DIR=/mutexa/raid5/data/mongodb
SSL_DIR=/mutexa/raid5/data/enzyhtp_gpt/ssl
FILES_DIR=/mutexa/raid5/data/enzyhtp_gpt/files
NGINX_LOG_DIR=/mutexa/raid5/data/enzyhtp_gpt/nginx/log

# 可选：Nginx 配置文件（默认 ./nginx.conf）
NGINX_CONF=./nginx.conf

# 可选：后端依赖路径
ENZYHTP_BIN=/home/zhongy8/bin/EnzyHTP
AMBER22_DIR=/sb/apps/amber22

# 可选：后端读取的数据库连接串（不设则使用服务名 mongo）
MONGO_URI=mongodb://mongo:27017/enzyhtp

# 可选：OpenAI 运行时（assistants | responses）
OPENAI_RUNTIME=responses
